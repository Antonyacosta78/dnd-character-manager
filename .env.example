# Rules provider and integrity behavior
RULES_PROVIDER="derived"
DATA_INTEGRITY_MODE="strict"

# Database
DATABASE_URL="file:./prisma/dev.db"

# External data source input (example path)
EXTERNAL_DATA_PATH="./external/data-source/data"
IMPORTER_VERSION="foundation-v1"

# Better Auth
BETTER_AUTH_SECRET="replace-with-32-char-secret"
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_TELEMETRY=0

# existing observability gates
OBSERVABILITY_ENABLED=false
NEXT_PUBLIC_OBSERVABILITY_ENABLED=false

# environment + release
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=local-dev
NEXT_PUBLIC_SENTRY_RELEASE=local-dev

# DSNs
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project-id>
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project-id>
