# Rules provider and integrity behavior
RULES_PROVIDER="derived"
DATA_INTEGRITY_MODE="strict"

# Database
DATABASE_URL="file:./prisma/dev.db"

# External source input (5etools)
EXTERNAL_DATA_PATH="./external/5etools/data"

# Auth.js
AUTH_SECRET="replace-with-32-char-secret"
AUTH_URL="http://localhost:3000"
