# Rules provider and integrity behavior
RULES_PROVIDER="derived"
DATA_INTEGRITY_MODE="strict"

# Database
DATABASE_URL="file:./prisma/dev.db"

# External source input 
EXTERNAL_DATA_PATH="./external/5etools/data"
IMPORTER_VERSION="foundation-v1"

# Better Auth
BETTER_AUTH_SECRET="replace-with-32-char-secret"
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_TELEMETRY=0
